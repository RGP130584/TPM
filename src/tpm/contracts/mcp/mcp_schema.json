{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MCP Contract",
    "type": "object",
    "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "metadata": {
            "type": "object",
            "additionalProperties": true
        },
        "capabilities": {
            "type": "array",
            "items": { "type": "string" }
        }
    },
    "required": ["id", "name", "version"]
}
